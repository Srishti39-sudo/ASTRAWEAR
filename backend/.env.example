# Copy this file to .env and fill in your actual values

# Hugging Face (for Llama 3 AI)
HF_TOKEN=your_huggingface_token_here

# Geoapify (for location autocomplete)
GEOAPIFY_KEY=your_geoapify_api_key_here

# FreeAstroAPI (for Vedic astrology calculations)
ASTRO_API_KEY=your_freeastroapi_key_here

# MongoDB Atlas (REQUIRED - for user data and history)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/astrawear?retryWrites=true&w=majority
